{#This file is for the login form#}

{% extends "base.jinja" %}
{% from "components.jinja" import brand_logo %}

{% block title %}GREENSEER - Authentication{% endblock %}

{% block content %}
<div class="fixed inset-0 z-50 flex justify-center items-center p-4 bg-[radial-gradient(circle_at_center,theme(colors.surface-container-low)_0%,theme(colors.surface)_100%)]">
  <div class="bg-[#192540]/60 backdrop-blur-[20px] p-8 md:p-16 w-full max-w-[480px] border border-outline-ghost shadow-[0_20px_50px_rgba(0,0,0,0.5)]">

    <div class="mb-10 md:mb-16">
      {{ brand_logo(svg_classes="w-10 h-10 md:w-12 md:h-12", text_classes="text-[24px] md:text-[32px]") }}
    </div>

    <form action="/login" method="POST">
      <div class="mb-6 w-full">
        <label class="block font-space uppercase tracking-[0.1rem] text-[0.8rem] text-outline-variant mb-2">Email</label>
        <input type="text" name="email" placeholder="Enter identification code" class="w-full bg-surface-container-high border-b-2 border-primary text-on-surface p-4 font-sans text-base outline-none focus:shadow-[0_4px_15px_rgba(107,255,143,0.15)] transition-shadow duration-300">
      </div>
      
      <div class="mb-6 w-full">
        <label class="block font-space uppercase tracking-[0.1rem] text-[0.8rem] text-outline-variant mb-2">Password</label>
        <input type="password" name="password" placeholder="••••••••••••" class="w-full bg-surface-container-high border-b-2 border-primary text-on-surface p-4 font-sans text-base outline-none focus:shadow-[0_4px_15px_rgba(107,255,143,0.15)] transition-shadow duration-300">
      </div>

      <button type="submit" class="w-full bg-gradient-to-r from-primary to-primary-container text-on-primary font-space font-extrabold text-base uppercase tracking-[0.15em] p-[18px] mt-6 hover:brightness-125 transition-all duration-300">
        Log in
      </button>
    </form>
    
  </div>
</div>
{% endblock %}
